# Copier en .env et remplir les valeurs

# Sécurité
SECRET_KEY=change-me-avec-openssl-rand-hex-32

# Base de données (SQLite en dev, PostgreSQL en prod)
DATABASE_URL=sqlite:///./dev.db

# Redis (optionnel — désactivé si vide)
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL publique de l'app (pour les redirections Stripe)
APP_URL=http://localhost:8000
